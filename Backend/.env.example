# ============================================================
# ReservAqui — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Banco principal (hotéis + usuários globais)
DB_MASTER_NAME=reservaqui_master

# Máximo de conexões por pool de tenant (hotéis individuais)
DB_TENANT_MAX_CONNECTIONS=5

# ── Pasta dos bancos tenant ───────────────────────────────────
# Em produção (Linux) garanta que o usuário do app tem permissão de escrita
# Exemplo produção: /var/lib/reservaqui/bancos
# Exemplo dev local: deixe em branco (usa ./bancos na raiz do Backend)
BANCOS_DIR=

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=substitua_por_secret_seguro_de_64_bytes
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ── Argon2 (Criptografia) ─────────────────────────────────────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# ── Rota Padrão (API) ─────────────────────────────────────────────────────────
API_PREFIX=/api/v1
