# ============================================================
# ReservAqui — Variáveis de Ambiente
# Copie para .env e preencha os valores reais
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Banco principal (hotéis + usuários globais)
DB_MASTER_NAME=reservaqui_master

# Máximo de conexões por pool de tenant (hotéis individuais)
DB_TENANT_MAX_CONNECTIONS=5

# ── Pasta dos bancos tenant ───────────────────────────────────
# Em produção (Linux) garanta que o usuário do app tem permissão de escrita
# Exemplo produção: /var/lib/reservaqui/bancos
# Exemplo dev local: deixe em branco (usa ./bancos na raiz do Backend)
BANCOS_DIR=

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=substitua_por_secret_seguro_de_64_bytes
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ── Argon2 (Criptografia) ─────────────────────────────────────────────────────
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=1

# ── Rota Padrão (API) ─────────────────────────────────────────────────────────
API_PREFIX=/api/v1

# ── Admin Seed (credencial de apresentação/desenvolvimento) ───────────────────
# Usada por `src/database/seeds/seed.admin.ts` para criar o admin inicial.
# Seguro rodar em qualquer ambiente — o seed é idempotente (ON CONFLICT DO NOTHING).
# Em produção: após o deploy inicial, troque a senha pelo fluxo de change-password
# ou rotacione diretamente no banco. Nunca compartilhe essas credenciais fora do time.
ADMIN_SEED_EMAIL=admin@reservaqui.dev
ADMIN_SEED_SENHA=Admin@2026
ADMIN_SEED_NOME=Admin Reserva Aqui
ADMIN_SEED_CPF=00000000000
ADMIN_SEED_NASC=1990-01-01

# ── Storage Local de Imagens ───────────────────────────────────────────────────
# Diretório raiz para armazenar arquivos (relativo à raiz do Backend)
# Exemplo produção: /var/lib/reservaqui/storage
UPLOAD_DIR=./storage

# Tamanho máximo por imagem em megabytes
UPLOAD_MAX_SIZE_MB=10

# Limite de fotos de capa por hotel (por orientação: portrait e landscape independentes)
UPLOAD_MAX_HOTEL_COVER=5

# Limite de fotos por quarto (total — sem distinção de orientação)
UPLOAD_MAX_ROOM_PHOTOS=10

# ── Firebase Cloud Messaging ───────────────────────────────────────────────────
# JSON minificado da service account (Firebase Console → Project Settings → Service accounts)
# Sem esta variável, push notifications são no-op (console.warn)
FIREBASE_SERVICE_ACCOUNT=

# ── InfinitePay ────────────────────────────────────────────────────────────────
# Ativa o bypass da etapa de pagamento via link (cria a reserva direto)
INFINITEPAY_BYPASS=true

# InfiniteTag (sem o $ do início)
INFINITEPAY_HANDLE=sua_infinite_tag

# URL pública do backend (usada como webhook_url na criação do link InfinitePay)
BACKEND_URL=https://api.reservaqui.com

# URL pública do frontend (usada como redirect_url após pagamento concluído)
FRONTEND_URL=https://app.reservaqui.com

# ── Integração WhatsApp ───────────────────────────────────────────────────────
# Painel Meta:      https://developers.facebook.com/apps
# Business Suite:   https://business.facebook.com
# Token permanente do System User (Meta Business Suite → Usuários do sistema → Gerar token)
WHATSAPP_TOKEN=
# ID do número de telefone (Meta Developers → WhatsApp → Configuração da API)
WHATSAPP_PHONE_ID=
# Senha livre para validar o Webhook (deve coincidir com o painel da Meta)
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── IA: Gemini (Google) ───────────────────────────────────────────────────────
# Painel (criar/gerenciar API keys): https://aistudio.google.com/apikey
# Cotas e uso (Cloud Console):       https://console.cloud.google.com/apis/api/generativelanguage.googleapis.com/quotas
# Free tier: 20 req/dia por modelo (2.5-flash/flash-lite) em projetos novos.
# SUPORTE MULTI-KEY (Round-Robin): Você pode adicionar múltiplas chaves separadas por vírgula.
# Exemplo: GEMINI_API_KEY=chave1,chave2,chave3 (Isso multiplica seu limite de uso)
GEMINI_API_KEY=

# ── IA: Groq (fallback + processamento de áudio/imagem) ───────────────────────
# Painel (criar API keys):    https://console.groq.com/keys
# Dashboard de uso/rate limit: https://console.groq.com/dashboard/usage
# Modelos usados no projeto:
#   - Chat:   llama-3.3-70b-versatile         (tool calling)
#   - Áudio:  whisper-large-v3-turbo          (STT para voice notes do WhatsApp)
#   - Visão:  meta-llama/llama-4-scout-17b-16e-instruct  (descrição + OCR de imagens)
# Free tier: ~14k req/dia, 12k tokens/min.
# SUPORTE MULTI-KEY (Round-Robin): Você pode adicionar múltiplas chaves separadas por vírgula.
# Exemplo: GROQ_API_KEY=chave1,chave2,chave3 (Isso previne erros 429 - Rate Limit)
GROQ_API_KEY=

# ── Seletor de provider primário ──────────────────────────────────────────────
# Valores aceitos: gemini | groq. O outro provider vira fallback automático em 429/erro.
AI_PRIMARY_PROVIDER=groq

# ── LangSmith (Observabilidade) ───────────────────────────────────────────────
# Painel (traces, filtros, custo por run): https://smith.langchain.com
# NÃO existe CLI oficial — o painel é web. Basta abrir a URL acima no navegador após logar.
# Criar conta e projeto:
#   1. Acesse https://smith.langchain.com e entre com Google/GitHub.
#   2. Settings → API Keys → Create API Key. Copie para LANGCHAIN_API_KEY abaixo.
#   3. (Opcional) Crie um projeto explicitamente; senão o LangChain cria sozinho ao receber o 1o trace.
# Quando LANGCHAIN_TRACING_V2=true, cada invocação LangChain (LLM, tool, agent) é enviada
# automaticamente ao painel — sem mudança de código.
# Para filtrar por conversa no painel, busque por "session_id" ou pelo nome do run.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=reservaqui-chatbot
# Endpoint customizado (deixe em branco para usar https://api.smith.langchain.com padrão)
LANGCHAIN_ENDPOINT=

# ── SMTP / Email (Nodemailer) ─────────────────────────────────────────────────
# Usado para envio de emails transacionais (reserva pendente/confirmada/expirada).
# Sem SMTP_HOST, o serviço vira no-op (console.warn) e o fluxo continua.
# Exemplos de providers:
#   Gmail:    SMTP_HOST=smtp.gmail.com         SMTP_PORT=587
#   Mailtrap: SMTP_HOST=sandbox.smtp.mailtrap.io SMTP_PORT=2525
#   SendGrid: SMTP_HOST=smtp.sendgrid.net      SMTP_PORT=587 SMTP_USER=apikey
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="ReservAqui <noreply@reservaqui.app>"

# ── Rate-limit dos endpoints públicos de reserva/pagamento ────────────────────
# Janela em ms e número máximo de requisições por IP por janela.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_GUEST_RESERVA_MAX=5
RATE_LIMIT_PAGAMENTO_MAX=10

# ⚠️  IMPORTANTE: Após preencher WHATSAPP_TOKEN/PHONE_ID, é necessário assinar a WABA ao App.
#     Consulte .context/whatsapp_context.md (seção "WABA Subscription") para detalhes.

