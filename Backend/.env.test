NODE_ENV=test

# DB (mocked in unit tests; values just need to be defined)
DB_HOST=localhost
DB_PORT=5432
DB_USER=test
DB_PASSWORD=test
DB_MASTER_NAME=reservaqui_test_master
DB_TENANT_MAX_CONNECTIONS=1
BANCOS_DIR=

PORT=0
API_PREFIX=/api/v1

# Auth — deterministic test secrets
JWT_SECRET=test_jwt_secret_for_unit_tests_only_change_in_prod
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Uploads
UPLOAD_DIR=./tmp_test_storage
UPLOAD_MAX_SIZE_MB=10
UPLOAD_MAX_HOTEL_COVER=5
UPLOAD_MAX_ROOM_PHOTOS=10

# External integrations — disabled / bypassed in tests
FIREBASE_SERVICE_ACCOUNT=
INFINITEPAY_BYPASS=true
INFINITEPAY_HANDLE=test_handle
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:8080

WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=test_verify_token

GEMINI_API_KEY=
GROQ_API_KEY=
AI_PRIMARY_PROVIDER=groq
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=reservaqui-test
LANGCHAIN_ENDPOINT=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
