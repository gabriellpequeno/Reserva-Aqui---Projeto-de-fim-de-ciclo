{
  "name": "reservaqui-backend",
  "version": "1.0.0",
  "description": "ReservAqui Backend — Multi-tenant hotel reservation system",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/app.js",
    "prod": "npm run build && npm run start",
    "db:reset": "ts-node --transpile-only src/scripts/reset-db.ts",
    "db:seed": "ts-node --transpile-only src/database/seeds/index.ts",
    "db:seed:hotels": "ts-node --transpile-only src/database/seeds/seed.hotels.ts",
    "db:seed:recommended": "ts-node --transpile-only src/database/seeds/seed.recommendedRooms.ts",
    "db:seed:my-rooms": "ts-node --transpile-only src/database/seeds/seed.my-rooms-page.ts",
    "db:seed:reservas": "ts-node --transpile-only src/database/seeds/seed.reservas.ts",
    "db:seed:push": "ts-node --transpile-only src/database/seeds/seed.push-fcm.ts",
    "db:seed:catalogo": "ts-node --transpile-only src/database/seeds/seed.catalogo-default.ts",
    "db:migrate:cleanup-categorias": "ts-node --transpile-only src/database/seeds/migrate.cleanup-empty-categorias.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@langchain/core": "^1.1.41",
    "@langchain/google-genai": "^2.1.28",
    "@langchain/groq": "^1.2.0",
    "@types/multer": "^2.1.0",
    "argon2": "^0.44.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "file-type": "^22.0.1",
    "firebase-admin": "^13.8.0",
    "groq-sdk": "^1.1.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.12.0",
    "uuid": "^9.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.3.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
